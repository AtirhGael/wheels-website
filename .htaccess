# Elite BBS Rims - Apache Configuration

# Enable Rewrite Engine
<IfModule mod_rewrite.c>
    Options +FollowSymLinks
    RewriteEngine On
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Canonical: redirect non-www to www
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

    # Redirect .html to clean URL
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.+)\.html$ /$1 [R=301,L]

    # Handle clean URLs for pages
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^shop/?$ shop/index.php [L]
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^cart/?$ cart/index.php [L]
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^checkout/?$ checkout/index.php [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^product/([^/]+)/?$ product/index.php?slug=$1 [L]
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^blog/?$ blog/index.php [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^blog/([^/]+)/?$ blog/posts.php?slug=$1 [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect config files
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# PHP Settings
<IfModule mod_php7.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>

# Default index file
DirectoryIndex index.php index.html

# Error documents (optional)
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/gif               "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType text/css                "access plus 3 months"
    ExpiresByType application/javascript  "access plus 3 months"
    ExpiresByType application/x-javascript "access plus 3 months"
    ExpiresByType text/html               "access plus 1 hour"
</IfModule>

